# Azure AI Foundry
AZURE_AI_ENDPOINT=https://<resource>.services.ai.azure.com/openai/v1
AZURE_AI_KEY=<api-key>
AZURE_AI_DEPLOYMENT=Kimi-K2.6

# Partner model for CHP adjudication (dual-model consensus)
AZURE_AI_PARTNER_DEPLOYMENT=gpt-4o
USE_PARTNER_MODEL=true

# Data providers
ALPHAVANTAGE_API_KEY=
FRED_API_KEY=
TWELVE_DATA_API_KEY=

# Microsoft Fabric
FABRIC_WORKSPACE_ID=<workspace-guid>
FABRIC_LAKEHOUSE_ID=<lakehouse-guid>
